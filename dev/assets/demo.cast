[0.389, "o", "\u001b[?2026h\u001b[1;1H\u001b[0m\u001b[38;5;75m‚ē≠‚ĒÄ\u001b[0m\u001b[38;5;75m\u001b[1m ‚Ėł Model Editor \u001b[0m\u001b[38;5;75m‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ēģ\u001b[0m\u001b[38;5;237m‚ē≠‚ĒÄ\u001b[0m\u001b[38;5;75m\u001b[1m Sampling \u001b[0m\u001b[38;5;237m‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ēģ‚ē≠‚ĒÄ\u001b[0m\u001b[38;5;75m\u001b[1m Diagnostics \u001b[0m\u001b[38;5;237m‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ēģ\u001b[2;1H\u001b[0m\u001b[38;5;75m‚Ēā\u001b[2;3H\u001b[0m\u001b[38;5;242m1‚Ēā\u001b[0m\u001b[38;5;183m\u001b[1m@skate\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;178mSchools\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;75m\u001b[1mbegin\u001b[2;43H\u001b[0m\u001b[38;5;75m‚Ēā\u001b[0m\u001b[38;5;237m‚Ēā\u001b[0m\u001b[38;5;253mReady ‚ÄĒ define data in the \u001b[2;75H\u001b[0m\u001b[38;5;237m‚Ēā‚Ēā\u001b[0m\u001b[38;5;253mWaiting for sampling\u001b[2;108H\u001b[0m\u001b[38;5;237m‚Ēā\u001b[3;1H\u001b[0m\u001b[38;5;75m‚Ēā\u001b[3;3H\u001b[0m\u001b[38;5;242m2‚Ēā\u001b[0m\u001b[38;5;252m    \u001b[0m\u001b[38;5;183m\u001b[1m@constants\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;75m\u001b[1mbegin\u001b[3;43H\u001b[0m\u001b[38;5;75m‚Ēā\u001b[0m\u001b[38;5;237m‚Ēā\u001b[0m\u001b[38;5;253mREPL, then press F5 to compile\u001b[0m\u001b[38;5;237m‚Ēā‚Ēā\u001b[3;108H‚Ēā\u001b[4;1H\u001b[0m\u001b[38;5;75m‚Ēā\u001b[4;3H\u001b[0m\u001b[38;5;242m3‚Ēā\u001b[0m\u001b[38"]
[0.000, "o", ";5;252m        \u001b[0m\u001b[38;5;245mJ::\u001b[0m\u001b[38;5;178mInt\u001b[4;43H\u001b[0m\u001b[38;5;75m‚Ēā\u001b[0m\u001b[38;5;237m‚Ēā\u001b[0m\u001b[38;5;253mand run\u001b[4;75H\u001b[0m\u001b[38;5;237m‚Ēā‚Ēā\u001b[4;108H‚Ēā\u001b[5;1H\u001b[0m\u001b[38;5;75m‚Ēā\u001b[5;3H\u001b[0m\u001b[38;5;242m4‚Ēā\u001b[0m\u001b[38;5;252m        \u001b[0m\u001b[38;5;245my::\u001b[0m\u001b[38;5;178mVector\u001b[0m\u001b[38;5;245m{\u001b[0m\u001b[38;5;178mFloat64\u001b[0m\u001b[38;5;245m}\u001b[5;43H\u001b[0m\u001b[38;5;75m‚Ēā\u001b[0m\u001b[38;5;237m‚Ēā\u001b[5;75H‚Ēā‚Ēā\u001b[5;108H‚Ēā\u001b[6;1H\u001b[0m\u001b[38;5;75m‚Ēā\u001b[6;3H\u001b[0m\u001b[38;5;242m5‚Ēā\u001b[0m\u001b[38;5;252m        \u001b[0m\u001b[38;5;245msigma::\u001b[0m\u001b[38;5;178mVector\u001b[0m\u001b[38;5;245m{\u001b[0m\u001b[38;5;178mFloat64\u001b[0m\u001b[38;5;245m}\u001b[6;43H\u001b[0m\u001b[38;5;75m‚Ēā\u001b[0m\u001b[38;5;237m‚Ēā\u001b[6;75H‚Ēā‚Ēā\u001b[6;108H‚Ēā\u001b[7;1H\u001b[0m\u001b[38;5;75m‚Ēā\u001b[7;3H\u001b[0m\u001b[38;5;242m6‚Ēā\u001b[0m\u001b[38;5;252m    \u001b[0m\u001b[38;5;75m\u001b[1mend\u001b[7;43H\u001b[0m\u001b[38;5;75m‚Ēā\u001b[0m\u001b[38;5;237m‚Ēā\u001b[7;75H‚Ēā‚Ēā\u001b[7;108H‚Ēā\u001b[8;1H\u001b[0m\u001b[38;5;75m‚Ēā\u001b[8;3H\u001b[0m\u001b[38;5;242m7‚Ēā\u001b[0m\u001b[38;5;252m    \u001b[0m\u001b[38;5;183m\u001b[1m@params\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;75m\u001b[1mbegin\u001b[8;43H\u001b[0m\u001b[38;5;75m‚Ēā\u001b[0m\u001b[38;5;237m‚Ēā\u001b[8;75H‚Ēā‚Ēā\u001b[8;108H‚Ēā\u001b[9;1H\u001b[0m\u001b[38;5;75m‚Ēā\u001b[9;3H\u001b[0m\u001b[38;5;242m8‚Ēā\u001b[0m\u001b["]
[0.000, "o", "38;5;252m        \u001b[0m\u001b[38;5;253mmu\u001b[0m\u001b[38;5;245m::\u001b[0m\u001b[38;5;178mFloat64\u001b[9;43H\u001b[0m\u001b[38;5;75m‚Ēā\u001b[0m\u001b[38;5;237m‚Ēā\u001b[9;75H‚Ēā‚Ēā\u001b[9;108H‚Ēā\u001b[10;1H\u001b[0m\u001b[38;5;75m‚Ēā\u001b[10;3H\u001b[0m\u001b[38;5;242m9‚Ēā\u001b[0m\u001b[38;5;252m        \u001b[0m\u001b[38;5;253mtau\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;255m=\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;253mparam\u001b[0m\u001b[38;5;245m(\u001b[0m\u001b[38;5;178mFloat64\u001b[0m\u001b[38;5;245m;\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;253mlower\u001b[0m\u001b[38;5;255m=\u001b[0m\u001b[38;5;114m0.0\u001b[0m\u001b[38;5;75m‚Ēā\u001b[0m\u001b[38;5;237m‚Ēā\u001b[10;75H‚Ēā‚Ēā\u001b[10;108H‚Ēā\u001b[11;1H\u001b[0m\u001b[38;5;75m‚Ēā\u001b[0m\u001b[38;5;242m10‚Ēā\u001b[0m\u001b[38;5;252m        \u001b[0m\u001b[38;5;253mtheta_raw\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;255m=\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;253mparam\u001b[0m\u001b[38;5;245m(\u001b[0m\u001b[38;5;178mVector\u001b[0m\u001b[38;5;245m{\u001b[0m\u001b[38;5;178mFloat\u001b[0m\u001b[38;5;75m‚Ēā\u001b[0m\u001b[38;5;237m‚ēį‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ēĮ‚ēį‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ēĮ\u001b[12;1H\u001b[0m\u001b[38;5;75m‚Ēā\u001b[0m\u001b[38;5;242m11‚Ēā\u001b[0m\u001b[38;5;252m    \u001b[0m\u001b[38;5;75m\u001b[1me"]
